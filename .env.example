# Required: Operator private key (hex with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...
# Agent runtime / demo agents / bootstrap (Dev 2)
OPERATOR_PRIVATE_KEY=0x...
BASESCAN_API_KEY=

# Optional: Runtime RPC URL (Dev 2). `RPC_URL` is canonical for runtime code.
RPC_URL=https://sepolia.base.org
# Backward-compatible alias also supported by the runtime and used by Hardhat docs.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Trace service URL (defaults to local stub on :7403)
TRACE_SERVICE_URL=http://localhost:7403

# Optional: Private key for the local trace stub signer
TRACE_STUB_SIGNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional: Agent salt for deriving agentId (defaults to "intentguard-demo-agent-v1")
AGENT_SALT=intentguard-demo-agent-v1

# Optional: Metadata URI used during `npm run bootstrap`
AGENT_METADATA_URI=ipfs://stub/agent-metadata

# Optional: Merchant address for mock x402 (defaults to 0x0000000000000000000000000000000000000A01)
MERCHANT_ADDRESS=0x0000000000000000000000000000000000000a01

# Optional: Port overrides
DEMO_PORT=7402
MOCK_X402_PORT=7404

# Addresses set at deploy time (Dev 1 fills after first deploy)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
TRACE_ACK_SIGNER=0x0000000000000000000000000000000000000000
REVIEWER_SIGNER=0x0000000000000000000000000000000000000000
