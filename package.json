{
  "name": "intentguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18 <23"
  },
  "workspaces": [
    "apps/web",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm --workspace web run dev",
    "build": "npm run build:runtime && npm run build:web",
    "build:runtime": "tsc -p tsconfig.json",
    "build:web": "npm --workspace web run build",
    "start": "npm --workspace web run start",
    "lint": "npm --workspace web run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "bootstrap": "tsx scripts/bootstrap-agent.ts",
    "reset": "tsx scripts/reset.ts",
    "demo": "tsx services/demo-control/src/index.ts",
    "mock-x402": "tsx services/mock-x402/src/index.ts",
    "agent:legit": "tsx agents/legit.ts",
    "agent:blocked": "tsx agents/blocked.ts",
    "agent:overspend": "tsx agents/overspend.ts",

    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test:contracts": "hardhat test",
    "deploy:base-sepolia": "hardhat ignition deploy ignition/modules/Deploy.ts --network baseSepolia"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.2",
    "express": "^4.21.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition-ethers": "0.15.5",
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "16.4.5",
    "hardhat": "2.28.0",
    "ts-node": "10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}