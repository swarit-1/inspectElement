{
  "name": "intentguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18 <23"
  },
  "workspaces": [
    "apps/web",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm --workspace web run dev",
    "build": "npm run build:runtime && npm run build:web",
    "build:runtime": "tsc -p tsconfig.json",
    "build:web": "npm --workspace web run build",
    "start": "npm --workspace web run start",
    "lint": "npm --workspace web run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "bootstrap": "tsx scripts/bootstrap-agent.ts",
    "reset": "tsx scripts/reset.ts",
    "demo": "tsx services/demo-control/src/index.ts",
    "trace-stub": "tsx packages/trace/src/trace-stub-server.ts",
    "mock-x402": "tsx services/mock-x402/src/index.ts",
    "agent:legit": "tsx agents/legit.ts",
    "agent:blocked": "tsx agents/blocked.ts",
    "agent:overspend": "tsx agents/overspend.ts",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test:contracts": "cd test && hardhat test --config ../hardhat.config.cts",
    "deploy:params:base-sepolia": "tsx scripts/buildDeployParameters.ts base-sepolia",
    "deploy:params:localhost": "tsx scripts/buildDeployParameters.ts localhost",
    "deploy:write-manifest:base-sepolia": "tsx scripts/writeArtifacts.ts base-sepolia 84532",
    "deploy:write-manifest:localhost": "tsx scripts/writeArtifacts.ts localhost 31337",
    "deploy:base-sepolia": "npm run deploy:params:base-sepolia && hardhat ignition deploy ignition/modules/Deploy.ts --network baseSepolia --parameters ignition/parameters/base-sepolia.json && npm run deploy:write-manifest:base-sepolia",
    "deploy:localhost": "npm run deploy:params:localhost && hardhat ignition deploy ignition/modules/Deploy.ts --network hardhat --parameters ignition/parameters/localhost.json && npm run deploy:write-manifest:localhost"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.48.0",
    "@openzeppelin/contracts": "5.0.2",
    "@privy-io/react-auth": "^3.22.1",
    "@privy-io/wagmi": "^4.0.5",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.1",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "siwe": "^3.0.0",
    "viem": "^2.21.0",
    "wagmi": "^3.6.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.2",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "16.4.5",
    "hardhat": "^3.4.0",
    "ts-node": "10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
