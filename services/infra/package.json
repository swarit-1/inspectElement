{
  "name": "@intentguard/infra",
  "version": "0.1.0",
  "private": true,
  "description": "IntentGuard off-chain verifier & infra services: manifest pinning, trace pinning + TraceAck signing, event indexer, read-model API, challenge prep, reviewer stub.",
  "type": "module",
  "main": "dist/services/infra/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/services/infra/src/server.js",
    "dev": "tsx watch src/server.ts",
    "indexer": "tsx src/indexer/run.ts",
    "indexer:prod": "node --enable-source-maps dist/services/infra/src/indexer/run.js",
    "reindex": "tsx scripts/reindex.ts",
    "reset": "tsx scripts/reset.ts",
    "keygen": "tsx scripts/keygen.ts",
    "smoke": "tsx scripts/smoke-trace.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "hardhat": "3.4.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "viem": "^2.21.40",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
